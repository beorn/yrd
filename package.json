{
  "name": "git-bay",
  "version": "0.0.1",
  "private": true,
  "description": "Yrd bay — the Git-native bay implementation; git bay remains the compatibility command surface",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": "github:beorn/yrd",
  "type": "module",
  "bin": {
    "yrd": "bin/yrd.ts",
    "git-yrd": "bin/git-yrd.ts",
    "git-bay": "bin/git-bay.ts",
    "gitbay": "bin/git-bay.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "yrd": "bun ./bin/yrd.ts",
    "git-yrd": "bun ./bin/git-yrd.ts",
    "git-bay": "bun ./bin/git-bay.ts",
    "gitbay": "bun ./bin/git-bay.ts",
    "bay": "bun ./bin/git-bay.ts",
    "test": "bun --bun x vitest run",
    "check": "tsc --noEmit && bun --bun x vitest run",
    "spec": "PATH=\"$PWD/tests/bin:$PATH\" bun --bun x mdspec tests/gitbay.spec.md tests/batch.spec.md tests/refusals.spec.md tests/guide.spec.md"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "mdspec": "^0.4.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@silvery/commander": "^0.21.0"
  }
}
