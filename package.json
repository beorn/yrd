{
  "name": "git-yrd",
  "version": "0.0.1",
  "private": true,
  "description": "Composable software-development orchestration for tasks, bays, integration lines, and contests",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": "github:beorn/yrd",
  "homepage": "https://yrd.dev",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "yrd": "bin/yrd",
    "git-yrd": "bin/git-yrd",
    "git-bay": "bin/git-bay"
  },
  "scripts": {
    "yrd": "bun ./bin/yrd",
    "git-yrd": "bun ./bin/git-yrd",
    "git-bay": "bun ./bin/git-bay",
    "test": "bun --bun x vitest run",
    "check": "tsc --noEmit && bun --bun x vitest run"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@silvery/commander": "^0.21.0",
    "react": "^19.2.0",
    "silvery": "^0.21.0"
  }
}
