{
  "name": "git-yrd",
  "version": "0.0.1",
  "private": true,
  "description": "Composable software-development orchestration for tasks, bays, integration lines, and contests",
  "homepage": "https://yrd.dev",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": "github:beorn/yrd",
  "bin": {
    "git-bay": "dist/bin/git-bay",
    "git-yrd": "dist/bin/git-yrd",
    "yrd": "dist/bin/yrd"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "ARCHITECTURE.md",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "type": "module",
  "scripts": {
    "yrd": "bun ./bin/yrd",
    "git-yrd": "bun ./bin/git-yrd",
    "git-bay": "bun ./bin/git-bay",
    "build": "bun ./scripts/build.ts",
    "prepack": "bun run build",
    "test": "NODE_ENV=test bun --bun x vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:hh": "tsc --noEmit -p tsconfig.hh.json",
    "check": "bun run typecheck && bun run test",
    "check:hh": "bun run typecheck:hh && bun run test"
  },
  "dependencies": {
    "@silvery/command": "^0.21.0",
    "@silvery/commander": "^0.21.0",
    "@silvery/scope": "^0.21.0",
    "@silvery/signals": "^0.21.0",
    "loggily": "^0.10.2",
    "react": "^19.2.0",
    "silvery": "^0.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  }
}
